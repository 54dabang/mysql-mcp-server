SERVER_PORT=8083

# External MySQL connection. For MySQL running on the Docker host, keep
# host.docker.internal. For another container or server, set its host/IP.
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=ledger
MYSQL_SERVER_TIMEZONE=Asia/Shanghai

# Optional: set the full JDBC URL to override MYSQL_HOST/MYSQL_PORT/MYSQL_DATABASE.
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=oneapimmysql
SPRING_DATASOURCE_DATABASE=ledger

CONFIG_DATABASE_READ_ONLY_TABLES=ctg_ledger_annual_budget,ctg_ledger_project,ctg_ledger_project_expense_detail,ctg_ledger_project_user,sys_user,sys_dept
CONFIG_DATABASE_READ_ROWS_LIMIT=200

JAVA_OPTS=
